  m_Script: {fileID: 11500000, guid: c68968869f8246541b97081ad4ee1cb7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AvisoPlataformaSalto
  textoFase1Caida: "El salto de regreso es imposible desde aqu\xED... y esta extra\xF1a
    plataforma no parece reaccionar a mi presencia. Tendr\xE9 que explorar el fondo
    de esta fosa para encontrar una salida."
  textoFase2Bucle: "La plataforma sigue apagada... Ese guardi\xE1n corrupto de adelante
    debe ser la clave para reactivar la esencia de este lugar."
  textoFase3Activa: "Siento c\xF3mo el poder del bosque reactiv\xF3 este mecanismo
    espiritual. Ahora que est\xE1 en funcionamiento, podr\xE9 volver a las plataformas
    superiores."
  tiempoVisible: 5
  velocidadFade: 2
  textMeshPro: {fileID: 460273114}
